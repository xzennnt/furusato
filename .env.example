NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# Gunakan "json" untuk lokal tanpa database, atau "mysql" untuk production.
DATA_DRIVER=mysql
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# Alternatif jika provider memberi satu connection string:
MYSQL_URL=
MYSQL_CONNECTION_LIMIT=5
MYSQL_AUTO_SEED=true

# Upload gambar production memakai Vercel Blob.
UPLOAD_DRIVER=blob
BLOB_ACCESS=public
BLOB_READ_WRITE_TOKEN=
MAX_UPLOAD_BYTES=8388608

# Admin production. Jika dikosongkan, backend memakai data dari JSON/MySQL.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=
