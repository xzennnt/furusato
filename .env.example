NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# Gunakan "json" untuk lokal, "firestore" untuk Firebase Firestore.
DATA_DRIVER=json

# Admin production. Jika dikosongkan, backend memakai data dari JSON/Firestore.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Firestore: isi salah satu format credential di bawah ini saat akun Firebase sudah siap.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIRESTORE_DATABASE_ID=
FIRESTORE_LOCATION_ID=asia-southeast2

# Jika document Firestore masih kosong, data awal dari server/data/*.json otomatis disalin.
FIRESTORE_AUTO_SEED=true
